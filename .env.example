# ╔══════════════════════════════════════════════════════════════════╗
# ║  Festival Platform Template — Environment Variables             ║
# ║                                                                 ║
# ║  Copy this file to .env.local and fill in your values.          ║
# ║  Only DATABASE_URL is required. Everything else is OPTIONAL     ║
# ║  and enables additional features via graceful degradation.      ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Branding (white-label) ───────────────────────────────────────
# These values define your festival identity across the entire site.
# See src/config/site.ts for the full configuration reference.
NEXT_PUBLIC_SITE_URL=https://www.your-festival.com
NEXT_PUBLIC_SITE_NAME=Festival Name
NEXT_PUBLIC_SITE_TAGLINE=Music, Culture & Experiences
NEXT_PUBLIC_CONTACT_EMAIL=info@your-festival.com
NEXT_PUBLIC_VENUE_NAME=Festival Venue
NEXT_PUBLIC_VENUE_MAPS_URL=

# ── Social Links (optional) ─────────────────────────────────────
# Leave empty to hide the corresponding icon in the footer.
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_TIKTOK=
NEXT_PUBLIC_SOCIAL_YOUTUBE=

# ── Database (required) ─────────────────────────────────────────
# PostgreSQL connection string. Supports Neon, Supabase, Railway, etc.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB

# ── Dashboard Auth ───────────────────────────────────────────────
# Single admin password for /dashboard access.
# In production, use a strong randomly generated password.
ADMIN_PASSWORD=

# ── Session Signing (required in production) ─────────────────────
# Cryptographic secret for admin session tokens (edge-compatible HMAC-SHA256).
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── CSRF Protection (required in production) ─────────────────────
# Secret for CSRF token generation (HMAC-SHA256).
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# ── Privacy / GDPR ──────────────────────────────────────────────
# Salt for hashing IP addresses before storage (rate limiting).
# Generate with: openssl rand -hex 16
IP_HASH_SALT=

# ── Redis (optional) ────────────────────────────────────────────
# Enables distributed rate limiting across serverless instances.
# Without Redis: uses in-memory rate limiting (single-instance, OK for most).
# Supports standard Redis URL or Upstash REST API.
REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Sanity CMS (optional) ───────────────────────────────────────
# When configured: events, site config, and content managed via /studio.
# When not configured: uses src/config/events.ts + DB as data sources.
# See: https://www.sanity.io/docs/getting-started
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=
# Webhook secret for on-demand ISR revalidation from Sanity.
# Set this in Sanity Dashboard → API → Webhooks.
SANITY_REVALIDATE_SECRET=

# ── Stripe Checkout (optional) ──────────────────────────────────
# When configured: events with price_cents show native Stripe checkout.
# When not configured: falls back to Ticketmaster/external ticket links.
# See: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook secret for payment confirmations (checkout.session.completed).
# Set up webhook endpoint: https://your-site.com/api/v1/webhooks/stripe
# Events to listen: checkout.session.completed, checkout.session.expired
STRIPE_WEBHOOK_SECRET=

# ── Ticketmaster (optional) ─────────────────────────────────────
# Discovery API key for embedded ticket widgets.
# Fallback when Stripe is not configured for an event.
TM_API_KEY=

# ── Sentry (optional) ───────────────────────────────────────────
# Error tracking and performance monitoring.
# Server-side DSN (never exposed to client):
SENTRY_DSN=
# Client-side DSN (public, embedded in browser bundle):
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads during build:
SENTRY_AUTH_TOKEN=

# ── Analytics (optional) ────────────────────────────────────────
# Only loaded after user accepts cookies (GDPR compliant).
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
