# === Database ===
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB

# === Sentry (error tracking) ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# === Ticketmaster ===
TM_API_KEY=

# === Analytics (only loaded if user accepts cookies) ===
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# === Dashboard Auth ===
ADMIN_PASSWORD=

# === Redis (distributed rate limiting + lead queue) ===
REDIS_URL=

# === Session signing (generate with: openssl rand -hex 32) ===
# Required for edge-verified admin sessions in production
SESSION_SECRET=

# === CSRF Protection (generate with: openssl rand -hex 32) ===
CSRF_SECRET=

# === Privacy / GDPR ===
IP_HASH_SALT=

# === Sanity CMS (optional — template works without it) ===
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# === Application ===
NEXT_PUBLIC_SITE_URL=https://www.your-festival.com
NEXT_PUBLIC_SITE_NAME=Festival Name
