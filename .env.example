# ╔══════════════════════════════════════════════════════════════════╗
# ║  Festival Platform Template — Environment Variables             ║
# ║                                                                 ║
# ║  Copy this file to .env.local and fill in your values.          ║
# ║  Only DATABASE_URL is required. Everything else is OPTIONAL     ║
# ║  and enables additional features via graceful degradation.      ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Database (required) ─────────────────────────────────────────
# Matches docker-compose.yml defaults out of the box.
DATABASE_URL=postgres://festival:festival@localhost:5432/festival

# ── Branding (white-label) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=My Festival
NEXT_PUBLIC_SITE_TAGLINE=Music, Culture & Experiences
NEXT_PUBLIC_CONTACT_EMAIL=admin@claritystructures.com
NEXT_PUBLIC_VENUE_NAME=Main Venue
NEXT_PUBLIC_VENUE_MAPS_URL=

# ── Social Links (optional — leave empty to hide icons) ──────────
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_TIKTOK=
NEXT_PUBLIC_SOCIAL_YOUTUBE=

# ── Dashboard Auth ───────────────────────────────────────────────
ADMIN_PASSWORD=admin123

# ── Session / Security ─────────────────────────────────────────
# REQUIRED — minimum 32 characters. Generate with: openssl rand -base64 48
SESSION_SECRET=GENERATE-ME-run-openssl-rand-base64-48
CSRF_SECRET=dev-csrf-change-me-in-production
IP_HASH_SALT=dev-salt-change-me

# ── Redis (optional) ────────────────────────────────────────────
# Without Redis: uses in-memory rate limiting (OK for local dev).
REDIS_URL=

# ── Sanity CMS (optional) ──────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# ── Stripe Checkout (optional) ──────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Ticketmaster (optional) ─────────────────────────────────────
TM_API_KEY=

# ── Sentry (optional) ──────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Analytics (optional — loaded after cookie consent) ──────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
